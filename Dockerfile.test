FROM ubuntu:22.04

RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y \
    ca-certificates \
    sudo \
    git \
    bash \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY . /workspace
RUN git config --global --add safe.directory /workspace \
    && tools/setup-toolchain-linux.sh
