diff --git a/Makefile b/Makefile
index bea015c..93a12d7 100644
--- a/Makefile
+++ b/Makefile
@@ -338,7 +338,16 @@ $(KERNEL_BIN): $(KERNEL_ELF)
 
 # Userland
 USER_SYSCALL_O = $(BUILD_DIR)/$(USER_ARCH_DIR)/syscall.o
+# USR-LIB-01 (fixed): lib.c used to #include kernel/lib/{math,string,vsnprintf}.c
+# directly. Those three functions are now implemented independently under
+# user/sys/lib/ (libc_string.c, libc_math.c, libc_vsnprintf.c) with no
+# dependency on the kernel tree, built via the existing
+# $(BUILD_DIR)/$(USER_DIR)/sys/lib/%.o pattern rule below like any other
+# userland source, and linked into every ELF alongside lib.o.
 USER_LIB_O     = $(BUILD_DIR)/$(USER_SYS_DIR)/lib/lib.o \
+                 $(BUILD_DIR)/$(USER_SYS_DIR)/lib/libc_string.o \
+                 $(BUILD_DIR)/$(USER_SYS_DIR)/lib/libc_math.o \
+                 $(BUILD_DIR)/$(USER_SYS_DIR)/lib/libc_vsnprintf.o \
                  $(BUILD_DIR)/$(USER_SYS_DIR)/lib/portability/os1_video_platform.o \
                  $(BUILD_DIR)/$(USER_SYS_DIR)/lib/portability/d3d9/os1_d3d9_present.o \
                  $(BUILD_DIR)/$(USER_SYS_DIR)/lib/portability/opengl/os1_gl_platform.o
